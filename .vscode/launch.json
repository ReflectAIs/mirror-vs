{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: watch",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Tests",
      "type": "node",
      "request": "launch",
      "autoAttachChildProcesses": true,
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": [
        "run",
        "${input:scopeTestsFileName}"
      ],
      "smartStep": true,
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "scopeTestsFileName",
      "type": "promptString",
      "description": "Partial file name to scope test debugging to. Leave blank to run all tests."
    }
  ]
}

