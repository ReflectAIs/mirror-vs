.git/**
.github/**
.vscode/**
.DS_Store
.gitignore
tsconfig.json
esbuild.js
package-lock.json
node_modules/**
out/**
scratch/**
turns.log
*.vsix

# Ignore all source code files except the webview static assets
src/agent/**
src/providers/**
src/services/**
src/types/**
src/utils/**
src/extension.ts

# But include webview static assets and media
!media/logo.png

# Exclude loose source files in src root
src/*.ts
src/*.mjs
src/*.md
src/scripts/**
src/webview/**

# Exclude design docs and dev-only assets
*.design.md

# Exclude duplicate root-level files
logo.png
memory.md
plan.md
vitest.config.ts
.mirror-vs/**
.mirror-vs-backup/**
public/**
check_syntax.js
test_regex.js
build-check.mjs
vision.md
.git-changes.design.md
src/scripts/**
*.ts.map
*.d.ts
