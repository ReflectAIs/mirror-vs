.git/**
.github/**
.vscode/**
.DS_Store
.gitignore
tsconfig.json
esbuild.js
package-lock.json
node_modules/**
out/**
scratch/**
turns.log
*.vsix

# Ignore all source code files except the webview static assets
src/agent/**
src/providers/**
src/services/**
src/types/**
src/utils/**
src/extension.ts

# But include webview static assets and media
!media/logo.png
!src/webview/sidebar.html
!src/webview/sidebar.css
!src/webview/sidebar.js

# Exclude duplicate root-level files
logo.png
memory.md
plan.md
vitest.config.ts
.mirror-vs/**
