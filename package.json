{
  "name": "mirror-vs",
  "displayName": "Mirror VS",
  "description": "An interactive, sidebar-based AI coding assistant for VS Code supporting local Ollama and DeepSeek APIs with streaming completions.",
  "version": "0.2.0",
  "publisher": "DipeshMajithia",
  "author": "Dipesh Majithia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DipeshMajithia/mirror-vs"
  },
  "bugs": {
    "url": "https://github.com/DipeshMajithia/mirror-vs/issues"
  },
  "homepage": "https://github.com/DipeshMajithia/mirror-vs#readme",
  "keywords": [
    "ai",
    "assistant",
    "copilot",
    "chat",
    "ollama",
    "deepseek",
    "autonomous",
    "agent"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages",
    "Keymaps",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:mirror-vs.sidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mirror-vs-container",
          "title": "Mirror VS",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mirror-vs-container": [
        {
          "type": "webview",
          "id": "mirror-vs.sidebar",
          "name": "Mirror AI Worker",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "mirror-vs.focusSidebar",
        "title": "Focus Mirror VS Sidebar",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.clearChat",
        "title": "Clear Active Chat Session",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.acceptReview",
        "title": "Accept Changes",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.rejectReview",
        "title": "Reject Changes",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.acceptAllReviews",
        "title": "Accept All Changes",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.diffReview",
        "title": "Compare Changes",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.fixSelection",
        "title": "Fix with Mirror VS",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.explainSelection",
        "title": "Explain with Mirror VS",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.prevChange",
        "title": "Previous Review Change",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.nextChange",
        "title": "Next Review Change",
        "category": "Mirror VS"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "mirror-vs.fixSelection",
          "when": "editorHasSelection",
          "group": "mirror-vs@1"
        },
        {
          "command": "mirror-vs.explainSelection",
          "when": "editorHasSelection",
          "group": "mirror-vs@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mirror-vs.focusSidebar",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "mirror-vs.acceptReview",
        "key": "alt+enter",
        "mac": "alt+enter"
      },
      {
        "command": "mirror-vs.acceptReview",
        "key": "ctrl+enter",
        "mac": "ctrl+enter",
        "when": "mirror-vs.inReview"
      },
      {
        "command": "mirror-vs.prevChange",
        "key": "alt+k",
        "mac": "alt+k",
        "when": "mirror-vs.inReview"
      },
      {
        "command": "mirror-vs.nextChange",
        "key": "alt+j",
        "mac": "alt+j",
        "when": "mirror-vs.inReview"
      },
      {
        "command": "mirror-vs.fixSelection",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorHasSelection"
      },
      {
        "command": "mirror-vs.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "mirror-vs.clearChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "Mirror VS Assistant Settings",
      "properties": {
        "mirror-vs.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "The API base URL for your local Ollama instance."
        },
        "mirror-vs.defaultOllamaModel": {
          "type": "string",
          "default": "llama3",
          "description": "The default local Ollama model to use when starting a chat."
        },
        "mirror-vs.defaultDeepSeekModel": {
          "type": "string",
          "default": "deepseek-v4-pro",
          "enum": [
            "deepseek-chat",
            "deepseek-coder",
            "deepseek-reasoner",
            "deepseek-v4-flash",
            "deepseek-v4-pro"
          ],
          "description": "The DeepSeek model to use."
        },
        "mirror-vs.defaultProvider": {
          "type": "string",
          "default": "ollama",
          "description": "The default active LLM provider when launching the assistant."
        },
        "mirror-vs.contextBudgetPercent": {
          "type": "integer",
          "default": 75,
          "description": "Context window budget utilization percentage."
        },
        "mirror-vs.agentInputTokenBudget": {
          "type": "integer",
          "default": 6000,
          "description": "Adaptive soft input token budget (in tokens)."
        },
        "mirror-vs.agentInputTokenHardMax": {
          "type": "integer",
          "default": 200000,
          "description": "Generous ceiling for auto-derived budget path for long-context models."
        },
        "mirror-vs.teacherEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable teacher-student escalation loop on self-hosted/local model failures."
        },
        "mirror-vs.teacherModel": {
          "type": "string",
          "default": "deepseek-v4-pro",
          "description": "Model to use as the senior teacher model for failure recovery (format: provider/model)."
        },
        "mirror-vs.maxTurnsBeforeSummarize": {
          "type": "integer",
          "default": 16,
          "description": "Maximum turns before the conversation context is compressed."
        },
        "mirror-vs.turnsToRetain": {
          "type": "integer",
          "default": 6,
          "description": "Number of recent turns to retain as active conversation context after compression."
        },
        "mirror-vs.planFirst": {
          "type": "boolean",
          "default": true,
          "description": "Enforce Plan-First Execution Mode. The agent must declare an <implementation_plan> before executing file modifications."
        },
        "mirror-vs.deepSeekThinking": {
          "type": "boolean",
          "default": true,
          "description": "Enable DeepSeek V4 Thinking Mode."
        },
        "mirror-vs.deepSeekThinkingLevel": {
          "type": "string",
          "enum": [
            "high",
            "max"
          ],
          "default": "high",
          "description": "DeepSeek V4 Thinking Effort Level."
        },
        "mirror-vs.customSystemPrompt": {
          "type": "string",
          "default": "",
          "description": "A custom instructions prefix prepended to the agent's system prompt (e.g. 'Prefer functional components')."
        },
        "mirror-vs.agentMode": {
          "type": "string",
          "enum": [
            "normal",
            "refactor",
            "debug"
          ],
          "default": "normal",
          "description": "Select the active agent mode. Normal is for general tasks, Refactor focuses on restructuring, Debug attaches to debugger."
        },
        "mirror-vs.customEndpointEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable custom OpenAI-compatible API endpoint provider."
        },
        "mirror-vs.customEndpointUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL of the OpenAI-compatible endpoint (e.g. Together, Groq, vLLM, Azure)."
        },
        "mirror-vs.customEndpointModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Default model name for the custom endpoint."
        },
        "mirror-vs.customApis": {
          "type": "array",
          "default": [],
          "description": "List of configured custom OpenAI-compatible API providers.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "models": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "name",
              "url",
              "models"
            ]
          }
        },
        "mirror-vs.maxToolOutputLength": {
          "type": "integer",
          "default": 20000,
          "description": "Maximum character length for tool execution output in conversation history. Excess output is tokens."
        },
        "mirror-vs.enableTruncationGuardrail": {
          "type": "boolean",
          "default": true,
          "description": "Prevent the agent from accidentally truncating files (deleting >50% of lines in files over 50 lines)."
        },
        "mirror-vs.aiReviewEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable post-save AI code review. After saving a file, Mirror VS will analyze your changes and provide suggestions."
        },
        "mirror-vs.multiFileRefactorEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable atomic multi-file refactoring with automatic rollback on failure."
        },
        "mirror-vs.embeddingModel": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "Ollama embedding model for semantic search. Requires Ollama running with this model pulled."
        },
        "mirror-vs.autonomousMode": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, Mirror VS will automatically accept file changes after a 10-second countdown instead of waiting for manual approval. Enables fully agentic autonomous execution."
        },
        "mirror-vs.embeddingSearchMinScore": {
          "type": "number",
          "default": 0.3,
          "description": "Minimum similarity score threshold for embedding-based semantic search results."
        },
        "mirror-vs.maxEmbeddingResults": {
          "type": "integer",
          "default": 10,
          "description": "Maximum results returned from embedding-based semantic search."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --minify",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "postinstall": "npm run compile",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 200",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "powershell -Command vitest run",
    "test:watch": "powershell -Command vitest",
    "test:coverage": "powershell -Command vitest run --coverage",
    "check": "npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@types/node": "^18.17.1",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "ovsx": "^0.10.12",
    "prettier": "^3.8.3",
    "typescript": "^5.1.6",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "puppeteer-core": "^25.0.4"
  }
}