
{
  "name": "mirror-vs",
  "displayName": "Mirror VS",
  "description": "An interactive, sidebar-based AI coding assistant for VS Code supporting local Ollama and DeepSeek APIs with streaming completions.",
  "version": "0.0.1",
  "publisher": "DipeshMajithia",
  "author": "Dipesh Majithia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DipeshMajithia/mirror-vs"
  },
  "bugs": {
    "url": "https://github.com/DipeshMajithia/mirror-vs/issues"
  },
  "homepage": "https://github.com/DipeshMajithia/mirror-vs#readme",
  "keywords": [
    "ai",
    "assistant",
    "copilot",
    "chat",
    "ollama",
    "deepseek",
    "autonomous",
    "agent"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages",
    "Keymaps",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:mirror-vs.sidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mirror-vs-container",
          "title": "Mirror VS",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mirror-vs-container": [
        {
          "type": "webview",
          "id": "mirror-vs.sidebar",
          "name": "Mirror VS Assistant",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "mirror-vs.focusSidebar",
        "title": "Focus Mirror VS Sidebar",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.clearChat",
        "title": "Clear Active Chat Session",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.acceptReview",
        "title": "Accept Changes",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.rejectReview",
        "title": "Reject Changes",
        "category": "Mirror VS"
      },
      {
        "command": "mirror-vs.diffReview",
        "title": "Compare Changes",
        "category": "Mirror VS"
      }
    ],
    "configuration": {
      "title": "Mirror VS Assistant Settings",
      "properties": {
        "mirror-vs.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "The API base URL for your local Ollama instance."
        },
        "mirror-vs.defaultOllamaModel": {
          "type": "string",
          "default": "llama3",
          "description": "The default local Ollama model to use when starting a chat."
        },
        "mirror-vs.defaultDeepSeekModel": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "The DeepSeek model to use (e.g., deepseek-chat, deepseek-coder)."
        },
        "mirror-vs.defaultProvider": {
          "type": "string",
          "enum": [
            "ollama",
            "deepseek"
          ],
          "default": "ollama",
          "description": "The default active LLM provider when launching the assistant."
        },
        "mirror-vs.maxTurnsBeforeSummarize": {
          "type": "integer",
          "default": 16,
          "description": "Maximum turns before the conversation context is compressed."
        },
        "mirror-vs.turnsToRetain": {
          "type": "integer",
          "default": 6,
          "description": "Number of recent turns to retain as active conversation context after compression."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --minify",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "postinstall": "npm run compile",
    "lint": "eslint 'src/**/*.ts' --max-warnings 100",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@types/node": "^18.17.1",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^5.1.6",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "puppeteer-core": "^25.0.4"
  }
}
