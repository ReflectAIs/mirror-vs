{
  "name": "mirror-vs",
  "displayName": "Mirror VS",
  "description": "SOTA Autonomous Developer Agent for Gemma 4 E4B",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mirror-vs.start",
        "title": "Mirror VS: Start Agent"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mirror-vs-sidebar",
          "title": "Mirror VS",
          "icon": "$(mirror)"
        }
      ]
    },
    "views": {
      "mirror-vs-sidebar": [
        {
          "type": "webview",
          "id": "mirror-vs.chatView",
          "name": "Mirror Chat"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "cheerio": "^1.2.0",
    "ollama": "^0.5.0",
    "turndown": "^7.2.4",
    "uuid": "^9.0.1"
  }
}
